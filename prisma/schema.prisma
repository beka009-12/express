generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== ENUMS ======================

// ? Роли пользователей
enum UserRole {
  ADMIN
  OWNER
  USER
}

// ? Статусы заказов для управления жизненным циклом заказа
enum OrderStatus {
  PENDING // новый заказ
  PAID // оплачен
  PROCESSING // в обработке у продавца
  SHIPPED // отправлен
  COMPLETED // доставлен
  CANCELED // отменён
}

// ? Статусы платежей для интеграции с платежными системами
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryMethod {
  PICKUP // самовывоз
  COURIER_BISHKEK // курьер по Бишкеку
  COURIER_REGION // по регионам КР
  EXPRESS // срочная доставка
}

// ? Дополнительные атрибуты для одежды
enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum Season {
  SPRING_SUMMER
  AUTUMN_WINTER
  ALL_SEASON
}

// ? Типы промоакций для баннеров
enum PromoType {
  PERCENT
  FIXED_PRICE
  BUY_ONE_GET
  SEASONAL
}

enum BannerStatus {
  PENDING
  APPROVED
  REJECTED
}

// todo Модели

// ! Пользователи и магазины

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  avatar    String?
  phone     String?
  role      UserRole  @default(USER)
  deletedAt DateTime?

  cartItems Cart[]
  orders    Order[]
  stores    Store[]
  favorites Favorite[]
  addresses Address[] // добавил
  reviews   Review[] // добавил
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Store {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  address     String?
  region      String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  rating      Decimal? @db.Decimal(3, 2)

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products Product[]
  reviews  Review[] // добавил

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  banners   Banner[]
  orders    Order[]

  @@index([ownerId])
  @@map("stores")
}

// ! Категории и продукты

model Category {
  id       Int    @id @default(autoincrement())
  name     String
  parentId Int?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name, parentId])
  @@map("categories")
}

model Product {
  id         Int @id @default(autoincrement())
  storeId    Int
  categoryId Int

  title       String
  description String
  images      String[]

  brandName String?

  // Поля специально для одежды
  sku      String?  @unique
  sizes    String[]
  colors   String[]
  material String?
  gender   Gender?
  season   Season?

  price    Decimal  @db.Decimal(10, 2)
  newPrice Decimal? @db.Decimal(10, 2)

  stockCount Int @default(0)
  soldCount  Int @default(0)
  views      Int @default(0)

  isActive   Boolean   @default(true)
  archivedAt DateTime?

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  cartItems  Cart[]
  orderItems OrderItem[]
  favorites  Favorite[]
  reviews    Review[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  bannerProducts BannerProduct[]
  productImages  ProductImage[]

  @@index([storeId])
  @@index([categoryId])
  @@index([price])
  @@index([isActive])
  @@index([soldCount])
  @@map("products")
}

model ProductImage {
  id Int @id @default(autoincrement())

  productId Int

  url     String
  altText String?

  // ? Для главного изображения
  isMain    Boolean @default(false)
  // ? Для сортировки изображений в определённом порядке
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([productId, sortOrder])
  @@map("product_images")
}

// ! banners и промоакции 

model Banner {
  id      Int @id @default(autoincrement())
  storeId Int

  // Контент
  title       String // "Скидка"
  accent      String // "−50% на всю обувь Nike"
  description String // подзаголовок
  decoNum     String // "−50%", "1+1", "4990"
  promoTag    String // "Сезонная распродажа"
  color       String @default("#ef4444")

  // Логика скидок
  promoType  PromoType
  discount   Int? // % если PERCENT
  fixedPrice Decimal?  @db.Decimal(10, 2)

  // Статусы и модерация
  deadline     DateTime
  isActive     Boolean      @default(true)
  status       BannerStatus @default(PENDING)
  rejectReason String? // ПОЧЕМУ отклонили (важно для фидбека продавцу)

  // Связи
  slot     BannerSlot?
  products BannerProduct[]
  store    Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([status])
  @@index([deadline])
  @@map("banners")
}

model BannerSlot {
  id       Int @id @default(autoincrement())
  bannerId Int @unique

  // Финансы
  price  Decimal @default(500.00) @db.Decimal(10, 2) // Базовая цена
  isPaid Boolean @default(false)

  // Период показа
  startAt DateTime @default(now())
  endAt   DateTime

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([endAt])
  @@map("banner_slots")
}

model PromoCode {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  discount   Int // Например, 100 для полной скидки
  usageLimit Int      @default(1)
  usedCount  Int      @default(0)
  isActive   Boolean  @default(true)
  expiresAt  DateTime

  @@map("promo_codes")
}

model BannerProduct {
  id            Int     @id @default(autoincrement())
  bannerId      Int
  productId     Int
  originalPrice Decimal @db.Decimal(10, 2) // Цена на момент создания для истории

  banner  Banner  @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bannerId, productId])
  @@map("banner_products")
}

// ! Отзывы и адреса 

model Review {
  id        Int  @id @default(autoincrement())
  userId    Int
  productId Int
  storeId   Int?

  rating  Int      @db.SmallInt // 1-5
  comment String?
  images  String[]

  isApproved Boolean @default(true)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([productId])
  @@index([storeId])
  @@map("reviews")
}

model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  label     String // "Дом", "Работа" и т.д.
  name      String
  phone     String
  address   String
  city      String  @default("Бишкек")
  region    String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("addresses")
}

// ! Корзина и заказы

model Cart {
  id        Int @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id      Int @id @default(autoincrement())
  userId  Int
  storeId Int

  totalAmount  Decimal  @db.Decimal(10, 2)
  deliveryCost Decimal  @default(0) @db.Decimal(10, 2)
  platformFee  Decimal? @db.Decimal(10, 2)
  finalAmount  Decimal  @db.Decimal(10, 2)

  status         OrderStatus    @default(PENDING)
  deliveryMethod DeliveryMethod

  deliveryName    String
  deliveryPhone   String
  deliveryAddress String
  addressId       Int?

  trackingNumber String?

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store       @relation(fields: [storeId], references: [id])
  address   Address?    @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  paymentId Int?
  payment   Payment?    @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        Int @id @default(autoincrement())
  orderId   Int
  storeId   Int
  productId Int
  quantity  Int

  // Важно: цена на момент покупки
  priceAtBuy    Decimal  @db.Decimal(10, 2)
  newPriceAtBuy Decimal? @db.Decimal(10, 2) // если была акционная цена

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ! Платежи 

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int? // сделаем опциональным
  userId        Int
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  paymentMethod String

  transactionId String?
  paymentData   Json?

  user   User    @relation(fields: [userId], references: [id])
  orders Order[] // один платёж может относиться к нескольким заказам

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

// ! Избранное

model Favorite {
  id        Int @id @default(autoincrement())
  userId    Int
  productId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}
