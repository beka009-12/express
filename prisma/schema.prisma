generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== ENUMS ======================

enum UserRole {
  ADMIN
  OWNER
  USER
}

enum OrderStatus {
  PENDING // новый заказ
  PAID // оплачен
  PROCESSING // в обработке у продавца
  SHIPPED // отправлен
  COMPLETED // доставлен
  CANCELED // отменён
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryMethod {
  PICKUP // самовывоз
  COURIER_BISHKEK // курьер по Бишкеку
  COURIER_REGION // по регионам КР
  EXPRESS // срочная доставка
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum Season {
  SPRING_SUMMER
  AUTUMN_WINTER
  ALL_SEASON
}

// ====================== MODELS ======================

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  avatar    String?
  phone     String?
  role      UserRole  @default(USER)
  deletedAt DateTime?

  cartItems Cart[]
  orders    Order[]
  stores    Store[]
  favorites Favorite[]
  addresses Address[] // добавил
  reviews   Review[] // добавил

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Store {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  address     String?
  region      String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  rating      Decimal? @db.Decimal(3, 2)

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products Product[]
  reviews  Review[] // добавил

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("stores")
}

model Category {
  id       Int    @id @default(autoincrement())
  name     String
  parentId Int?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name, parentId])
  @@map("categories")
}

model Product {
  id         Int @id @default(autoincrement())
  storeId    Int
  categoryId Int

  title       String
  description String
  images      String[]

  brandName String?

  // Поля специально для одежды
  sku      String?  @unique
  sizes    String[]
  colors   String[]
  material String?
  gender   Gender?
  season   Season?

  price    Decimal  @db.Decimal(10, 2)
  newPrice Decimal? @db.Decimal(10, 2)

  stockCount Int @default(0)
  soldCount  Int @default(0)
  views      Int @default(0)

  isActive   Boolean   @default(true)
  archivedAt DateTime?

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  cartItems  Cart[]
  orderItems OrderItem[]
  favorites  Favorite[]
  reviews    Review[] // добавил

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([price])
  @@index([isActive])
  @@index([soldCount])
  @@map("products")
}

model Review {
  id        Int  @id @default(autoincrement())
  userId    Int
  productId Int
  storeId   Int?

  rating  Int      @db.SmallInt // 1-5
  comment String?
  images  String[]

  isApproved Boolean @default(true)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([productId])
  @@index([storeId])
  @@map("reviews")
}

model Address {
  id        Int     @id @default(autoincrement())
  userId    Int
  label     String // "Дом", "Работа" и т.д.
  name      String
  phone     String
  address   String
  city      String  @default("Бишкек")
  region    String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("addresses")
}

// Остальные модели без сильных изменений
model Cart {
  id        Int @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id     Int         @id @default(autoincrement())
  userId Int
  total  Decimal     @db.Decimal(10, 2)
  status OrderStatus @default(PENDING)

  deliveryMethod DeliveryMethod @default(COURIER_BISHKEK)
  deliveryCost   Decimal        @default(0) @db.Decimal(10, 2)
  trackingNumber String?

  deliveryName    String
  deliveryPhone   String
  deliveryAddress String

  addressId Int? // связь с Address
  address   Address? @relation(fields: [addressId], references: [id])

  platformFee Decimal? @db.Decimal(10, 2)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   OrderItem[]
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @unique
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  paymentMethod String

  transactionId String?
  paymentData   Json?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Favorite {
  id        Int @id @default(autoincrement())
  userId    Int
  productId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}
